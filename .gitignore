# GraphRAG deployment secrets (the .example.json is committed; the real one is not).
# Snapshots copy this file too; never commit those copies either.
infra/graphrag-deploy/configs/server_config.json
snapshots/**/server_config.json

# Dev scratch files at repo root (smoke tests, manual verify runs, etc.)
# Canonical eval results live in backend/tests/, not here.
/bench_*.json
/c[0-9]*_*.json
/p3_*.json
/ecc_trigger.json
/honest_test.json
/logs_*.txt
/backend/eval_*.log

# Rendered HTML doc artifacts (regenerated by scripts/render_docs.py on demand)
docs/html/*.html

